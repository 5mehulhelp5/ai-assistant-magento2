<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="comerix" translate="label" sortOrder="400">
            <label>Comerix</label>
        </tab>
        <section id="comerix_ai_assistant" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>AI Assistant</label>
            <tab>comerix</tab>
            <resource>Comerix_AiAssistant::config</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable AI Assistant</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="widget_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Widget Script URL</label>
                    <comment>URL of the AI Assistant widget script injected before &lt;/body&gt; on all frontend pages. Leave empty to disable.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="chat_server_url" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Chat Server URL</label>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="reindex_secret" translate="label comment" type="obscure" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Reindex Secret</label>
                    <comment>Secret key used to authorize reindex requests.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>
            <group id="widget_additional_config" translate="label" sortOrder="25" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Widget Additional Configurations</label>
                <field id="pp_widget_url" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Widget Script URL</label>
                    <comment>Embedded widget Script</comment>
                    <depends>
                        <field id="comerix_ai_assistant/general/enabled">1</field>
                    </depends>
                </field>
                <field id="enable_pp_widget" translate="label" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Product Page Quick Chat Widget</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="comerix_ai_assistant/general/enabled">1</field>
                    </depends>
                </field>
                <field id="enable_category_widget" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Category Bottom Widget</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="comerix_ai_assistant/general/enabled">1</field>
                    </depends>
                </field>
                <field id="enable_category_sidebar_widget" translate="label" type="select" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Category Sidebar Widget</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="comerix_ai_assistant/general/enabled">1</field>
                    </depends>
                </field>
                <field id="enable_cart_widget" translate="label" type="select" sortOrder="40" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable Cart Quick Chat Widget</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <depends>
                        <field id="comerix_ai_assistant/general/enabled">1</field>
                    </depends>
                </field>
            </group>
            <group id="indexes" translate="label" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Indexes</label>
                <field id="reindex_all" translate="label" type="button" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Reindex Products</label>
                    <frontend_model>Comerix\AiAssistant\Block\Adminhtml\System\Config\ReindexAll</frontend_model>
                </field>
                <field id="reindex_cms_pages" translate="label" type="button" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Reindex CMS Pages</label>
                    <frontend_model>Comerix\AiAssistant\Block\Adminhtml\System\Config\ReindexCmsPages</frontend_model>
                </field>
            </group>
        </section>
    </system>
</config>
