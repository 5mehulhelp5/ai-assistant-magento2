<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="magecloud" translate="label" sortOrder="400">
            <label>MageCloud</label>
        </tab>
        <section id="magecloud_ai_assistant" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>AI Assistant</label>
            <tab>magecloud</tab>
            <resource>MageCloud_AiAssistant::config</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Enable AI Assistant</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="widget_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Widget Script URL</label>
                    <comment>URL of the AI Assistant widget script injected before &lt;/body&gt; on all frontend pages. Leave empty to disable.</comment>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="chat_server_url" translate="label" type="text" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Chat Server URL</label>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
                <field id="reindex_secret" translate="label comment" type="obscure" sortOrder="40" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Reindex Secret</label>
                    <comment>Secret key used to authorize reindex requests.</comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends>
                        <field id="enabled">1</field>
                    </depends>
                </field>
            </group>
        </section>
    </system>
</config>
