<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="MageCloud\AiAssistant\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>

    <type name="MageCloud\AiAssistant\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">MageCloud_AiAssistant</argument>
            <argument name="handlers" xsi:type="array">
                <item name="debug" xsi:type="object">MageCloud\AiAssistant\Logger\Handler</item>
            </argument>
        </arguments>
    </type>

    <type name="MageCloud\AiAssistant\Controller\Restore\Index">
        <arguments>
            <argument name="logger" xsi:type="object">MageCloud\AiAssistant\Logger\Logger</argument>
        </arguments>
    </type>
</config>