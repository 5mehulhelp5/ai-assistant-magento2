<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="catalog_product_save_after">
        <observer name="comerix_ai_assistant_product_save_after"
                  instance="Comerix\AiAssistant\Observer\ProductSaveAfter"/>
    </event>
    <event name="catalog_product_delete_after">
        <observer name="comerix_ai_assistant_product_delete_after"
                  instance="Comerix\AiAssistant\Observer\ProductDeleteAfter"/>
    </event>
    <event name="cms_page_save_after">
        <observer name="comerix_ai_assistant_cms_page_save_after"
                  instance="Comerix\AiAssistant\Observer\CmsPageSaveAfter"/>
    </event>
    <event name="cms_page_delete_after">
        <observer name="comerix_ai_assistant_cms_page_delete_after"
                  instance="Comerix\AiAssistant\Observer\CmsPageDeleteAfter"/>
    </event>
</config>
