<?php
/** @var \Comerix\AiAssistant\Block\WidgetScript $block */
/** @var \Magento\Framework\Escaper $escaper */
$widgetUrl = $block->getWidgetUrl();
?>
<?php if ($widgetUrl):
    $pageType = $block->getPageType();
    $config = ['pageType' => $pageType];
    $config['pageUrl']  = $block->getPageUrl();
    $config['pageName'] = $block->getPageName();
    if ($block->getCustomerId() !== null) {
        $config['customerId'] = $block->getCustomerId();
    }
    if ($pageType === 'product') {
        $config['productSku']  = $block->getProductSku();
    } elseif ($pageType === 'category') {
        $config['categoryId'] = $block->getCategoryId();
    }
?>
<script>
window.comerixAiConfig = <?= /* @noEscape */ json_encode($config, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
</script>
<script src="<?= $escaper->escapeUrl($widgetUrl) ?>"
        data-server="<?= $escaper->escapeUrl($block->getChatServerUrl()) ?>"
        data-accent="<?= $escaper->escapeHtml($block->getWidgetColor()) ?>"
        data-title="<?= $escaper->escapeHtml($block->getTitle()) ?>"
        data-subtitle="<?= $escaper->escapeHtml($block->getSubtitle()) ?>"
        data-welcome="<?= $escaper->escapeHtml($block->getWelcomeMessage()) ?>"
        data-position="<?= $escaper->escapeHtml($block->getPosition()) ?>"
        defer>
</script>
<?php endif; ?>

